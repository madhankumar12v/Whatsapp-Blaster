# WhatsApp Blaster Configuration

# The password required to access the admin dashboard
LOGIN_PASSWORD=Snega@2023

# Server Port for the application (default is 3000)
PORT=3000

# Set to true for production or false for development mode
NODE_ENV=development

# Puppeteer configuration (for launching headless browser)
PUPPETEER_HEADLESS=true

# Configure message delay (in milliseconds) to avoid being flagged by WhatsApp
MIN_DELAY=1000
MAX_DELAY=5000

# Your WhatsApp Web settings (optional, for advanced setups)
WHATSAPP_WEB_URL=https://web.whatsapp.com

# Session management
SESSION_TIMEOUT=3600  # Timeout for session in seconds

# Log file path (for logging purposes)
LOG_FILE_PATH=./logs/whatsapp-blast.log

# Enable or disable real-time message tracking
ENABLE_REAL_TIME_TRACKING=true

# Set the base URL of the deployed application (for Webhooks, callbacks, etc.)
BASE_URL=https://your-domain.com

# Other optional settings
DEBUG=false
